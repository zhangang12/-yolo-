      "check": {
        "type": "compare",
        "path": "target.distance_m",
        "op": "ge",
        "threshold": 10
      },
      "mandatory": true,
      "severity": "critical",
      "source": "GB 50157-2013 28.2.3-4",
      "message": "同方向两安全出口 {target.exit_a} 与 {target.exit_b} 净距 {value}m < 10m"
    },
    {
      "rule_id": "EXIT-DIST-ADJ-001",
