        {
          "path": "target.zone_type",
          "op": "eq",
          "value": "equipment"
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.area_m2",
        "op": "le",
        "threshold": 2500
      },
      "mandatory": true,
      "severity": "critical",
      "source": "GB 51298-2018 4.3.2 / GB 50157-2013 28.2.2-3",
      "message": "地上设备区 {target.id} 面积 {value}㎡，超规范上限 2500㎡"
