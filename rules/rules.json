    {
      "rule_id": "AREA-EQUIP-ELEV-LOW-001",
      "name": "高架车站(≤24m)设备管理区分区面积",
      "category": "防火分区面积",
      "target": "fire_compartment",
      "applies_when": [
        {
          "path": "station.type",
          "op": "eq",
          "value": "elevated"
        },
        {
          "path": "station.height_m",
          "op": "le",
          "value": 24
        },
        {
          "path": "target.zone_type",
          "op": "eq",
          "value": "equipment"
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.area_m2",
        "op": "le",
        "threshold": 2500
