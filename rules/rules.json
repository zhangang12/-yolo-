{
  "version": "0.1",
  "updated": "2026-06-03",
  "comment": "MVP 规则集。来源：《消防检查规则》(用户提供，2026-06 版) + GB 51298-2018 / GB 50157-2013 / GB 50016-2014。每条只在适用条件成立时触发；同一指标下'地下/地上/高架'是分支不是冲突。",
  "rules": [
    {
      "rule_id": "AREA-PUB-001",
      "name": "站厅公共区防火分区面积",
      "category": "防火分区面积",
      "target": "fire_compartment",
      "applies_when": [
        {
          "path": "target.zone_type",
          "op": "eq",
          "value": "public"
        },
        {
          "path": "target.is_shared_concourse",
          "op": "ne",
          "value": true
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.area_m2",
        "op": "le",
        "threshold": 5000
      },
      "mandatory": false,
      "severity": "warning",
      "source": "GB 51298-2018 4.3.1",
      "message": "公共区 {target.id} 面积 {value}㎡，超规范上限 5000㎡（不宜）"
    },
    {
      "rule_id": "AREA-PUB-TRANSFER-2L-001",
      "name": "两线换乘共用站厅公共区面积",
      "category": "防火分区面积",
      "target": "fire_compartment",
      "applies_when": [
        {
          "path": "target.zone_type",
          "op": "eq",
          "value": "public"
        },
        {
          "path": "target.is_shared_concourse",
          "op": "eq",
          "value": true
        },
        {
          "path": "station.transfer_lines",
          "op": "eq",
          "value": 2
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.area_m2",
        "op": "le",
        "threshold": 10000
      },
      "mandatory": true,
      "severity": "critical",
      "source": "SZDB/Z100-2014 1.2.3",
      "message": "两线共用站厅公共区 {target.id} 面积 {value}㎡，超规范上限 10000㎡"
    },
    {
      "rule_id": "AREA-PUB-TRANSFER-3L-001",
      "name": "三线及以上换乘共用站厅公共区面积",
      "category": "防火分区面积",
      "target": "fire_compartment",
      "applies_when": [
        {
          "path": "target.zone_type",
          "op": "eq",
          "value": "public"
        },
        {
          "path": "target.is_shared_concourse",
          "op": "eq",
          "value": true
        },
        {
          "path": "station.transfer_lines",
          "op": "ge",
          "value": 3
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.area_m2",
        "op": "le",
        "threshold": 15000
      },
      "mandatory": true,
      "severity": "critical",
      "source": "SZDB/Z100-2014 1.2.3",
      "message": "三线共用站厅公共区 {target.id} 面积 {value}㎡，超规范上限 15000㎡"
    },
    {
      "rule_id": "AREA-PUB-TRANSFER-3L-SPRINKLER-001",
      "name": "三线共用站厅 >10000㎡ 应设自动喷水灭火系统",
      "category": "防火分区面积",
      "target": "fire_compartment",
      "applies_when": [
        {
          "path": "target.zone_type",
          "op": "eq",
          "value": "public"
        },
        {
          "path": "target.is_shared_concourse",
          "op": "eq",
          "value": true
        },
        {
          "path": "station.transfer_lines",
          "op": "ge",
          "value": 3
        },
        {
          "path": "target.area_m2",
          "op": "gt",
          "value": 10000
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.has_sprinkler",
        "op": "eq",
        "threshold": true
      },
      "mandatory": true,
      "severity": "critical",
      "source": "SZDB/Z100-2014 1.2.3",
      "message": "三线共用站厅 {target.id} 面积 {target.area_m2}㎡ >10000㎡，但未设自动喷水灭火系统（has_sprinkler={value}）"
    },
    {
