    {
      "rule_id": "EVAC-DIST-ANY-001",
      "name": "站台/站厅公共区任一点至安全出口疏散距离",
      "category": "安全疏散",
      "target": "evac_distance_line",
      "applies_when": [
        {
          "path": "target.kind",
          "op": "eq",
          "value": "any_to_exit"
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.length_m",
        "op": "le",
        "threshold": 50
      },
      "mandatory": true,
      "severity": "critical",
      "source": "GB 50157-2013 28.2.7",
      "message": "疏散距离 {target.id} = {value}m，超规范上限 50m"
    },
    {
      "rule_id": "EVAC-DIST-EQUIP-BETWEEN-001",
      "name": "设备区房间疏散门位于两安全出口之间到最近出口距离",
      "category": "安全疏散",
      "target": "door",
      "applies_when": [
        {
          "path": "target.zone",
          "op": "eq",
          "value": "equipment"
        },
        {
          "path": "target.position",
          "op": "eq",
          "value": "between_exits"
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.distance_to_nearest_exit_m",
        "op": "le",
        "threshold": 40
      },
      "mandatory": true,
      "severity": "critical",
      "source": "GB 50157-2013 28.2.10-3",
      "message": "设备区房间门 {target.id} 距最近安全出口 {value}m > 40m"
    },
    {
      "rule_id": "EVAC-DIST-EQUIP-DEADEND-001",
      "name": "设备区袋形走道/尽端房间门到最近出口距离",
      "category": "安全疏散",
      "target": "door",
      "applies_when": [
        {
          "path": "target.zone",
          "op": "eq",
          "value": "equipment"
        },
        {
          "path": "target.position",
          "op": "eq",
          "value": "dead_end"
        }
      ],
      "check": {
        "type": "compare",
        "path": "target.distance_to_nearest_exit_m",
        "op": "le",
        "threshold": 22
      },
      "mandatory": true,
      "severity": "critical",
      "source": "GB 50157-2013 28.2.10-3",
      "message": "设备区袋形/尽端房间门 {target.id} 距最近安全出口 {value}m > 22m"
    },
    {
      "rule_id": "EXIT-NUM-PUB-001",
      "name": "站厅公共区直通地面安全出口数",
      "category": "安全出口",
      "target": "station",
      "applies_when": [],
      "check": {
        "type": "count",
        "collection_path": "target.public_zone.exits",
        "filter": [
          {
            "path": "item.leads_to",
            "op": "eq",
            "value": "ground"
          }
        ],
        "op": "ge",
        "threshold": 2
      },
      "mandatory": true,
      "severity": "critical",
      "source": "GB 51298-2018 5.1.4 / GB 50157-2013 28.2.3-1",
      "message": "站厅公共区直通地面安全出口共 {value} 个 < 规范下限 2 个"
    },
    {
      "rule_id": "EXIT-NUM-EQUIP-001",
      "name": "地下车站设备与管理用房区安全出口数",
      "category": "安全出口",
      "target": "station",
      "applies_when": [
        {
          "path": "station.type",
          "op": "eq",
          "value": "underground"
        }
      ],
      "check": {
        "type": "count",
        "collection_path": "target.equipment_zone.exits",
        "op": "ge",
        "threshold": 2
      },
      "mandatory": true,
      "severity": "critical",
      "source": "GB 50157-2013 28.2.3-3",
      "message": "地下设备与管理用房区安全出口共 {value} 个 < 规范下限 2 个"
    },
    {
      "rule_id": "EXIT-DIST-SAME-DIR-001",
      "name": "同方向设置的两个安全出口通道口净距",
      "category": "安全出口",
      "target": "exit_pair",
