# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ===== 保密图纸/业务数据（不入库，新成员单独索取）=====
*.pdf
*.dwg
*.dxf
*.zip
*.doc
*.docx
*.jpg
*.jpeg
*.png
# 解压/合并出来的数据目录
data/anno_*/
# 例外：示例 JSON 与文档可入
!examples/*.json

# 标注原始件
annotations.xml
docs/annotations*.xml
docs/*_en.xml
*.cvat

# ===== 训练 / 运行产物 =====
runs/
dataset/
*.pt
*_overlay.jpg
*_prelabel.xml
*_review.txt
e2e_out/
e2e_cache/
out/
*.log

# ===== 模型产物(仅干净文件:权重 + 评估图表,绝不含图纸)=====
# 放在 models/ 下,例外放行权重/曲线/配置;jpg 永远禁止(防训练/验证图纸拼图误入)
!models/**/*.pt
!models/**/*.png
!models/**/*.csv
!models/**/*.yaml
!models/**/*.md
models/**/*.jpg
models/**/*.jpeg

# 临时/缓存
_t/
_shot/

# 编辑器/系统
.vscode/
.idea/
.DS_Store
Thumbs.db
